    <runInMode>SystemModeWithoutSharing</runInMode>
    <screens>
        <name>scr_01_Change_Ownership_Lead</name>
        <label>Change Ownership</label>
        <locationX>176</locationX>
        <locationY>158</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>true</allowPause>
        <connector>
            <targetReference>ass_01_Update_Owner</targetReference>
        </connector>
        <fields>
            <name>dt_01_Change_Owner</name>
            <fieldText>&lt;p&gt;Change owner from :&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(247, 5, 5);&quot;&gt;{!fCurrentUser}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;to&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(90, 199, 2);&quot;&gt;{!fNewUser}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Confirm the change by pressing the &apos;OK&apos;-button, to cancel press the cross above the right upper corner of THIS window (see the picture below).&lt;/p&gt;&lt;p&gt;&lt;img src=&quot;https://movingintelligence--acc--c.documentforce.com/sfc/servlet.shepherd/version/download/0681q000005qywy?asPdf=false&amp;amp;operationContext=CHATTER&quot; alt=&quot;image.png&quot;&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <nextOrFinishButtonLabel>OK</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
