    </assignments>
    <description>Screen flow, to take owner ship of the Lead record</description>
    <formulas>
        <name>fCurrentUser</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!recordId.Owner:Group.Name},TRIM( {!recordId.Owner:User.FirstName}+ &apos; &apos; + {!recordId.Owner:User.MiddleName} + &apos; &apos; + {!recordId.Owner:User.LastName}))</expression>
    </formulas>
    <formulas>
        <name>fNewUser</name>
        <dataType>String</dataType>
        <expression>TRIM({!$User.FirstName} + &apos;  &apos; + {!$User.MiddleName} + &apos;  &apos; + {!$User.LastName})</expression>
    </formulas>
    <interviewLabel>scr - Lead - Take Ownership {!$Flow.CurrentDateTime}</interviewLabel>
    <label>scr - Lead - Take Ownership</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordUpdates>
        <name>dur_01_Lead</name>
