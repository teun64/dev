    <decisions>
        <name>Should_Case_be_Created</name>
        <label>Should Case be Created?</label>
        <locationX>226</locationX>
        <locationY>731</locationY>
        <defaultConnector>
            <targetReference>Account_Details</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>N</defaultConnectorLabel>
        <rules>
            <name>dec2Y</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Survey_Response_Score__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>6.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Query_Existing_Cases</targetReference>
            </connector>
            <label>Y</label>
        </rules>
    </decisions>
    <description>This flow is designed to run the post update automations on Customer Survey records</description>
    <environments>Default</environments>
    <formulas>
        <name>forCaseDescription</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!$Record.Survey_Response_Motivation__c})), {!$Record.Survey_Response_Motivation__c}, &apos;No motivation added by the customer&apos;)</expression>
    </formulas>
    <formulas>
        <name>forCaseOwner</name>
        <dataType>String</dataType>
        <expression>IF({!$Record.Account__r.Subscriptions_Activated__c} &gt;= 5 &amp;&amp; {!$Record.Account__r.Owner.IsActive} &amp;&amp; NOT({!$Record.Account__r.Owner.Integration_User__c}) &amp;&amp; NOT({!$Record.Account__r.Owner.isSysAdmin__c}), {!$Record.Account__r.OwnerId}, {!Query_Survey_Queue.Id})</expression>
    </formulas>
    <formulas>
        <name>forCasePriority</name>
        <dataType>String</dataType>
        <expression>CASE({!$Record.Survey_Response_Score__c},
0, &apos;High&apos;,
1, &apos;High&apos;,
2, &apos;High&apos;,
3, &apos;High&apos;,
4, &apos;High&apos;,
5, &apos;High&apos;,
6, &apos;High&apos;,
&apos;Medium&apos;
)</expression>
    </formulas>
    <formulas>
        <name>forCaseSubClassification</name>
        <dataType>String</dataType>
        <expression>CASE({!$Record.Survey_Response_Score__c},
0, &apos;NPS_Low&apos;,
1, &apos;NPS_Low&apos;,
2, &apos;NPS_Low&apos;,
3, &apos;NPS_Low&apos;,
4, &apos;NPS_Low&apos;,
5, &apos;NPS_Low&apos;,
6, &apos;NPS_Low&apos;,
7, &apos;NPS_Medium&apos;,
8, &apos;NPS_Medium&apos;,
&apos;NPS_High&apos;
)</expression>
    </formulas>
    <formulas>
        <name>forCaseSubject</name>
        <dataType>String</dataType>
        <expression>&apos;NPS Survey Response [Score: &apos; + TEXT({!$Record.Survey_Response_Score__c}) + &apos;]&apos;</expression>
    </formulas>
    <interviewLabel>rau - {!$Flow.CurrentDateTime}</interviewLabel>
    <label>rau - Customer Survey</label>
