    <decisions>
        <name>Does_Case_Exist</name>
        <label>Does Case Exist?</label>
        <locationX>50</locationX>
        <locationY>947</locationY>
        <defaultConnector>
            <targetReference>Query_Case_Recordtype</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>N</defaultConnectorLabel>
        <rules>
            <name>dec3Y</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Query_Existing_Cases.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
