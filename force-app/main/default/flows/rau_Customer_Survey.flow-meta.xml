        <locationX>226</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Should_Case_be_Created</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>N</defaultConnectorLabel>
        <rules>
            <name>dec1Y</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Campaign_Member.Id</leftValueReference>
