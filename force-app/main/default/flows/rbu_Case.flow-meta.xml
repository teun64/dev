    <formulas>
        <name>fAccountId</name>
        <dataType>String</dataType>
        <expression>IF(AND(ISBLANK({!$Record.Asset.AccountId}), ISBLANK({!$Record.AccountId}), NOT({!$Record.Hardware__r.Account_Hardware__r.Name} = &apos;NO-NAME&apos;)), {!$Record.Hardware__r.Account_Hardware__c},
IF(ISBLANK({!$Record.AccountId}), {!$Record.Asset.AccountId}, {!$Record.AccountId}))</expression>
    </formulas>
    <formulas>
        <name>fAccountMarket</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!$Record.Account.extId_5__c}) = 0, &apos;Security&apos;, &apos;Fleet&apos;)</expression>
    </formulas>
    <formulas>
        <name>fContactAccountMarket</name>
        <dataType>String</dataType>
        <expression>IF(LEN({!$Record.Contact.Account.extId_5__c}) = 0, &apos;Security&apos;, &apos;Fleet&apos;)</expression>
    </formulas>
    <formulas>
        <name>fContactEmail</name>
        <dataType>String</dataType>
        <expression>IF(
    AND(NOT(ISBLANK({!$Record.ContactId})), NOT(ISBLANK({!$Record.ContactEmail}))),
    {!$Record.ContactEmail},
    IF(
        AND(NOT(ISBLANK({!$Record.AccountId})), OR(NOT(ISBLANK({!$Record.Account.Billing_Email__c})), NOT(ISBLANK({!$Record.Account.Shipping_Email__c})))),
        IF(ISBLANK({!$Record.Account.Shipping_Email__c}), {!$Record.Account.Billing_Email__c}, {!$Record.Account.Shipping_Email__c}),
        {!$Record.SuppliedEmail}
    )
)</expression>
    </formulas>
    <formulas>
        <name>fContactId</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE(
    {!$Record.ContactId},
    BLANKVALUE(
        {!$Record.Asset.ContactId},
        {!$Record.Asset.Account.Contact_person__r.Id}
    )
)</expression>
    </formulas>
    <formulas>
        <name>fDomain</name>
        <dataType>String</dataType>
        <expression>RIGHT({!fEmail}, ( LEN({!fEmail}) - FIND(&apos;@&apos;,{!fEmail})))</expression>
    </formulas>
    <formulas>
        <name>fEmail</name>
        <dataType>String</dataType>
        <expression>LOWER({!$Record.SuppliedEmail})</expression>
    </formulas>
    <formulas>
        <name>fEntityIdentifier_Modified</name>
        <dataType>String</dataType>
        <expression>UPPER(SUBSTITUTE({!$Record.Entity_Identifier__c},&apos;-&apos;,&apos;&apos;))</expression>
    </formulas>
    <formulas>
        <name>fHardware</name>
        <dataType>String</dataType>
        <expression>IF(AND(ISBLANK({!$Record.Hardware__c}), NOT(ISBLANK({!$Record.AssetId}))), {!$Record.Asset.ParentId}, {!$Record.Hardware__c} )</expression>
    </formulas>
    <formulas>
        <name>fUserName</name>
        <dataType>String</dataType>
        <expression>LEFT({!fEmail}, (FIND(IF(AND((FIND(&apos;+&apos;,{!fEmail}) &gt; 0),FIND(&apos;+&apos;,{!fEmail})&lt;FIND(&apos;@&apos;,{!fEmail})),&apos;+&apos;,&apos;@&apos;),{!fEmail}) - 1))</expression>
    </formulas>
