    <decisions>
        <name>Account_Change_Check</name>
        <label>Account Change Check</label>
        <locationX>842</locationX>
        <locationY>1295</locationY>
        <defaultConnector>
            <targetReference>dec_Last_Queue_Set</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Account Change</defaultConnectorLabel>
        <rules>
            <name>dec_AccountCheck_Account_Changed</name>
            <conditionLogic>((1 AND 2) OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>$Record.AccountId</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.AccountId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.AccountId</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>ASR</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Account_Values</targetReference>
            </connector>
            <label>Account Changed</label>
        </rules>
        <rules>
            <name>Contact_Changed</name>
            <conditionLogic>1 OR (2 AND 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ContactId</leftValueReference>
                <operator>WasSet</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ContactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ContactId</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Contact_Values</targetReference>
            </connector>
            <label>Contact Changed</label>
        </rules>
    </decisions>
