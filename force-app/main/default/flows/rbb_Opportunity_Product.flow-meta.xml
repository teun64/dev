    <environments>Default</environments>
    <formulas>
        <name>fApprovalRequired</name>
        <dataType>Boolean</dataType>
        <expression>NOT(AND(({!fDiscount}&gt;=0),({!fDiscount} &lt;= {!fMarginAmount})))</expression>
    </formulas>
    <formulas>
        <name>fBasePrice</name>
        <dataType>Currency</dataType>
        <expression>IF((BLANKVALUE({!rPricebookEntry.From_Quantity_1__c},0)=1),{!rPricebookEntry.From_Price_1__c},{!rPricebookEntry.UnitPrice})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fDiscount</name>
        <dataType>Currency</dataType>
        <expression>BLANKVALUE(IF({!rPricebookEntry.Product2.Exclude_from_Discount__c},0,{!$Record.DiscountAmount__c}),0)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fDiscountPercentage</name>
        <dataType>Number</dataType>
        <expression>IF({!rPricebookEntry.Product2.Exclude_from_Discount__c},0,(BLANKVALUE({!fDiscount},0) / {!fSalesPrice} ))</expression>
        <scale>6</scale>
    </formulas>
    <formulas>
        <name>fFromPrice1</name>
        <dataType>Currency</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_1__c}),ISBLANK({!rProductDiscount.From_Quantity_1__c})), null, ROUND(({!rPricebookEntry.UnitPrice} * (1.00-({!rProductDiscount.From_Discount_1__c} / IF(OR(({!rProductDiscount.From_Discount_1__c}&gt;1),({!rProductDiscount.From_Discount_1__c}&lt;-1)),100,1)) )),2))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fFromPrice2</name>
        <dataType>Currency</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_2__c}),ISBLANK({!rProductDiscount.From_Quantity_2__c})), null, ROUND(({!rPricebookEntry.UnitPrice} * (1.00-({!rProductDiscount.From_Discount_2__c} / IF(OR(({!rProductDiscount.From_Discount_2__c}&gt;1),({!rProductDiscount.From_Discount_2__c}&lt;-1)),100,1)) )),2))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fFromPrice3</name>
        <dataType>Currency</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_3__c}),ISBLANK({!rProductDiscount.From_Quantity_3__c})), null, ROUND(({!rPricebookEntry.UnitPrice} * (1.00-({!rProductDiscount.From_Discount_3__c} / IF(OR(({!rProductDiscount.From_Discount_3__c}&gt;1),({!rProductDiscount.From_Discount_3__c}&lt;-1)),100,1)) )),2))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fFromPrice4</name>
        <dataType>Currency</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_4__c}),ISBLANK({!rProductDiscount.From_Quantity_4__c})), null, ROUND(({!rPricebookEntry.UnitPrice} * (1.00-({!rProductDiscount.From_Discount_4__c} / IF(OR(({!rProductDiscount.From_Discount_4__c}&gt;1),({!rProductDiscount.From_Discount_4__c}&lt;-1)),100,1)) )),2))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fFromQuantity1</name>
        <dataType>Number</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_1__c}),ISBLANK({!rProductDiscount.From_Quantity_1__c})), null, {!rProductDiscount.From_Quantity_1__c})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fFromQuantity2</name>
        <dataType>Number</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_2__c}),ISBLANK({!rProductDiscount.From_Quantity_2__c})), null, {!rProductDiscount.From_Quantity_2__c})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fFromQuantity3</name>
        <dataType>Number</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_3__c}),ISBLANK({!rProductDiscount.From_Quantity_3__c})), null, {!rProductDiscount.From_Quantity_3__c})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fFromQuantity4</name>
        <dataType>Number</dataType>
        <expression>IF(OR(ISBLANK({!rProductDiscount.From_Discount_4__c}),ISBLANK({!rProductDiscount.From_Quantity_4__c})), null, {!rProductDiscount.From_Quantity_4__c})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fMargin</name>
        <dataType>Number</dataType>
        <expression>IF( {!$Record.Quantity}&gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_4__c},9999999), 0,
IF( {!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_3__c},9999999), 0,
IF( {!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_2__c},9999999), 0,
IF( {!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_1__c},9999999), 0,BLANKVALUE({!rPricebookEntry.Margin__c},BLANKVALUE({!rPricebookEntry.Pricebook2.Sales_Margin__c},0)))
)
)
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fMarginAmount</name>
        <dataType>Currency</dataType>
        <expression>ROUND(({!fSalesPrice} * (BLANKVALUE({!fMargin},0)  / (IF(OR(({!fMargin}&gt;1),({!fMargin}&lt;-1)),100,1)))),2)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fSalesPrice</name>
        <dataType>Currency</dataType>
        <expression>IF( {!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_4__c},9999999), {!rPricebookEntry.From_Price_4__c},
IF( {!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_3__c},9999999), {!rPricebookEntry.From_Price_3__c},
IF({!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_2__c},9999999), {!rPricebookEntry.From_Price_2__c},
IF({!$Record.Quantity} &gt;= BLANKVALUE({!rPricebookEntry.From_Quantity_1__c},9999999), {!rPricebookEntry.From_Price_1__c},{!rPricebookEntry.UnitPrice})
)
)
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fUnitPrice</name>
        <dataType>Currency</dataType>
        <expression>{!fSalesPrice} - {!fDiscount}</expression>
        <scale>2</scale>
    </formulas>
