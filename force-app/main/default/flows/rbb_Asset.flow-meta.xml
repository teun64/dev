    </formulas>
    <formulas>
        <name>fAssembledBy</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE(TEXT({!$Record.Assembled_by__c}),TEXT({!$Record.Product2.Assembled_by__c}))</expression>
    </formulas>
    <formulas>
        <name>fDealerAccountActivated</name>
        <dataType>String</dataType>
        <expression>IF(AND(ISPICKVAL({!$Record.Status},&apos;6&apos;),NOT(ISBLANK({!$Record.Activationcode_used_on__c}))), BLANKVALUE({!$Record.Dealer_Account__c},null), null)</expression>
    </formulas>
    <formulas>
        <name>fDealerAccountNotActivated</name>
