        <expression>IF(AND(ISPICKVAL({!$Record.Status},&apos;6&apos;), ISBLANK({!$Record.Activationcode_used_on__c})), BLANKVALUE({!$Record.Dealer_Account__c}, null),null)</expression>
    </formulas>
    <formulas>
        <name>fDealerAccountStock</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!$Record.Status},&apos;8&apos;), BLANKVALUE({!$Record.Dealer_Account__c},null), null)</expression>
    </formulas>
    <formulas>
        <name>fObject</name>
        <dataType>String</dataType>
        <expression>IF(({!$Record.RecordType.DeveloperName}=&apos;Hardware&apos;),BLANKVALUE({!$Record.License_Plate__c},BLANKVALUE({!$Record.Chassis_Number__c},IF(ISBLANK({!$Record.Product2Id}),BLANKVALUE({!$Record.Hardware_Name__c},&apos;&apos;),{!$Record.Product2.Name}))),&apos;&apos;)</expression>
    </formulas>
