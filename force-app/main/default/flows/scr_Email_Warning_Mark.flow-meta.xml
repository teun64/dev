    <formulas>
        <name>fDomain</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!Get_Case.SuppliedEmail})),RIGHT({!Get_Case.SuppliedEmail}, ( LEN({!Get_Case.SuppliedEmail}) - FIND(&apos;@&apos;,{!Get_Case.SuppliedEmail}))),&apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>fUsername</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!Get_Case.SuppliedEmail})),LEFT({!Get_Case.SuppliedEmail}, (FIND(IF(AND((FIND(&apos;+&apos;,{!Get_Case.SuppliedEmail})&gt; 1),(FIND(&apos;+&apos;,{!Get_Case.SuppliedEmail})&lt; FIND(&apos;@&apos;,{!Get_Case.SuppliedEmail}))),&apos;+&apos;,&apos;@&apos;),{!Get_Case.SuppliedEmail}) - 1)),&apos;&apos;)</expression>
    </formulas>
