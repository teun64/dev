    <formulas>
        <name>fMarket</name>
        <dataType>String</dataType>
        <expression>&apos;&apos;
/*IF(OR(ISPICKVAL($Record.Account__c.Reseller_Name__c,&apos;1&apos;),ISPICKVAL($Record.Account__c.Reseller_Name__c,&apos;5&apos;)),&apos;&apos;,Text($Record.Account__c.Market__c))*/</expression>
    </formulas>
    <formulas>
        <name>fPriceBookType</name>
        <dataType>String</dataType>
        <expression>CASE({!$Record.Product__r.RecordType.DeveloperName}
,&apos;Subscription&apos;,&apos;Subscriptions&apos;
,(CASE(text({!$Record.Account__r.Relation_type__c})
,&apos;Distributor&apos;,  &apos;Distributors&apos;
,&apos;Dealer&apos;,&apos;Dealers&apos;
,&apos;Intercompany&apos;,&apos;Intercompany&apos;
,&apos;Leasing Company&apos;,&apos;Leasing Companies&apos;
,&apos;High Volume&apos;,&apos;High Volume (Consumer &amp; Business Users)&apos;
,&apos;Consumer &amp; Business Users&apos;))
)</expression>
    </formulas>
