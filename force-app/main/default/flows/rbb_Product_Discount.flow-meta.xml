    <formulas>
        <name>fCurrency</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!$Record.Account__r.Reseller_Name__c},&apos;6&apos;),&apos;GBP&apos;,&apos;EUR&apos;)</expression>
    </formulas>
    <formulas>
        <name>fFixedPrice1</name>
        <dataType>Number</dataType>
        <expression>IF(
(BLANKVALUE({!$Record.From_Quantity_1__c},0)&gt;=1)
,
ROUND (
(
( 1 - (BLANKVALUE({!$Record.From_Discount_1__c},0) /  IF(OR((BLANKVALUE({!$Record.From_Discount_1__c},0)&gt;1),(BLANKVALUE({!$Record.From_Discount_1__c},0)&lt;-1)),100,1))) 
*
{!vUnitPrice} 
)
,
2
)
,
{!cNumberNull}
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fFixedPrice2</name>
