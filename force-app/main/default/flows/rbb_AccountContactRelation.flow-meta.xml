    <formulas>
        <name>fCompositeKey</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!$Record.AccountId}, &apos;&lt;AccountId&gt;&apos;) +
BLANKVALUE({!$Record.ContactId}, &apos;&lt;ContactId&gt;&apos;)</expression>
    </formulas>
