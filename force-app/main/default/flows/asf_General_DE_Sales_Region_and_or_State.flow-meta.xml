    <description>Get State Codes and Sales Region from Country and Postal Code</description>
    <formulas>
        <name>fCountryCheck</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISBLANK({!vCountryCode})),(LEN(TRIM({!vCountryCode}))=2))</expression>
    </formulas>
    <formulas>
        <name>fPostalCode1</name>
        <dataType>Number</dataType>
        <expression>IF(ISNUMBER(LEFT(SUBSTITUTE({!vPostalCode},&apos; &apos;,&apos;&apos;),1)),VALUE(LEFT(SUBSTITUTE({!vPostalCode},&apos; &apos;,&apos;&apos;),1)),-1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Numeric part 2 digits postalcode</description>
        <name>fPostalCode2</name>
        <dataType>Number</dataType>
        <expression>IF(ISNUMBER(LEFT(SUBSTITUTE({!vPostalCode},&apos; &apos;,&apos;&apos;),2)),VALUE(LEFT(SUBSTITUTE({!vPostalCode},&apos; &apos;,&apos;&apos;),2)),-1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Numeric Postal Code, 5</description>
        <name>fPostalCode5</name>
        <dataType>Number</dataType>
        <expression>IF(ISNUMBER(LEFT(SUBSTITUTE({!vPostalCode},&apos; &apos;,&apos;&apos;),5)),VALUE(LEFT(SUBSTITUTE({!vPostalCode},&apos; &apos;,&apos;&apos;),5)),-1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fZipPostalCode</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISBLANK({!vPostalCode})),(LEN(SUBSTITUTE({!vPostalCode},&quot; &quot;,&quot;&quot;))&gt;=2))</expression>
    </formulas>
