    <formulas>
        <name>fCollectionDate</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Due_Date__c}
-
(
IF(ISPICKVAL({!$Record.Method__c},&apos;I0&apos;)
,
12
,
((FLOOR({!vProcessingTime}/5) * 7)  + MOD({!vProcessingTime}, 5))
)
)</expression>
    </formulas>
    <formulas>
        <name>fCollectionDateWeekend</name>
        <dataType>Date</dataType>
        <expression>({!$Record.Collection_Date__c}
-
CASE(WEEKDAY({!$Record.Collection_Date__c}),1,2,7,1,0) )</expression>
    </formulas>
