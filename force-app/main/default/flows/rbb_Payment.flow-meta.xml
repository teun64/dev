    </formulas>
    <formulas>
        <name>fType</name>
        <dataType>String</dataType>
        <expression>CASE(TEXT({!$Record.Method__c}),&apos;C&apos;,{!cTypeFSInCash},CASE(LEFT(LOWER(TEXT({!$Record.Method__c})),1),&apos;i&apos;,IF(ISPICKVAL({!$Record.Processor__c},&apos;Stripe&apos;),{!cTypePSPDirectDebit},{!cTypeFSDirectDebit}),&apos;p&apos;,{!cTypePSPImmediate},{!cTypeFSOnAccount}))</expression>
