    <description>Swaps a paid and closed won opportunity to a new opportunity with the opportunity products copied with a negative quantity</description>
    <environments>Default</environments>
    <formulas>
        <name>fClosedDate</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(Today(),1)</expression>
    </formulas>
    <formulas>
        <name>fDateLimit</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(TODAY(), -1)</expression>
    </formulas>
    <formulas>
        <name>fName</name>
        <dataType>String</dataType>
        <expression>{!recordId.Name} + &apos; (&apos; + {!$Label.SwappedVersion} + &apos;)&apos;</expression>
    </formulas>
    <formulas>
        <name>fSwappedAmountGross</name>
        <dataType>Currency</dataType>
        <expression>ROUND((BLANKVALUE({!recordId.Payment_Amount_Gross__c},0) + BLANKVALUE({!recordId.Swapped_Amount_Gross__c},0)),2)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fSwappedAmountNet</name>
        <dataType>Currency</dataType>
        <expression>ROUND((BLANKVALUE({!recordId.Payment_Amount_Net__c},0) + BLANKVALUE({!recordId.Swapped_Amount_Net__c},0)),2)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fSwappedAmountVAT</name>
        <dataType>Currency</dataType>
        <expression>ROUND((BLANKVALUE({!recordId.Payment_Amount_VAT__c},0) + BLANKVALUE({!recordId.Swapped_Amount_VAT__c},0)),2)</expression>
        <scale>2</scale>
    </formulas>
