    <formulas>
        <name>fAccountFinancialReady</name>
        <dataType>Boolean</dataType>
        <expression>NOT(
	OR(
		/* Account requirements */
		OR( 
			ISBLANK( {!$Record.AccountId} ), 
			ISBLANK( {!$Record.Account.FinancialDebtorNumber__c})
		),
		/* Bank Details*/
		AND(
			OR(
				(LEFT(UPPER(TEXT( {!$Record.Payment_Method__c} )),1) = &apos;I&apos;), 
				(UPPER(TEXT( {!$Record.Payment_Method__c} )) = &apos;P0&apos;)
			), 
			OR (
				ISBLANK( {!$Record.Account.Bank_Account_Number__c} ), 
				ISBLANK( {!$Record.Account.Bank_Account__c} )
			)
		),
		/* Billing Address */
		OR (
			ISBLANK( {!$Record.Account.BillingStreet} ), 
			ISBLANK( {!$Record.Account.BillingPostalCode} ), 
			ISBLANK( {!$Record.Account.BillingCity} )
		), 
		/* Shipping Address */
		OR (
			ISBLANK( {!$Record.Account.ShippingStreet} ), 
			ISBLANK( {!$Record.Account.ShippingPostalCode} ), 
			ISBLANK( {!$Record.Account.ShippingCity} )
		)
	)
)</expression>
    </formulas>
    <formulas>
        <name>fClosedDateEstimated</name>
        <dataType>Date</dataType>
        <expression>BLANKVALUE({!$Record.Close_Date_Estimated__c}, {!$Record__Prior.CloseDate})</expression>
    </formulas>
    <formulas>
        <name>fLicencePlate</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(UPPER(TRIM({!$Record.Licence_Plate__c}) ) ,&apos;-&apos;, &apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>fMarket</name>
        <dataType>String</dataType>
        <expression>&apos;&apos;
/*IF(OR(ISPICKVAL($Record.Account.Reseller_Name__c,&apos;1&apos;),ISPICKVAL($Record.Account.Reseller_Name__c,&apos;5&apos;)),&apos;&apos;,Text($Record.Account.Market__c))*/</expression>
    </formulas>
    <formulas>
        <name>fOptionActivationFeeRemark</name>
        <dataType>Boolean</dataType>
        <expression>OR(
INCLUDES({!$Record.Subscriptions__c},&apos;etAllinOne&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;etFiscalReports&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;etLiveTracking&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;etReporting&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiBlack&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiBlackR&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiOrange&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiOrangeR&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiWhite&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiBlue&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiRoyalBlue&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiAzure&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiGreen&apos;)
,INCLUDES({!$Record.Subscriptions__c},&apos;MiRed&apos;)
