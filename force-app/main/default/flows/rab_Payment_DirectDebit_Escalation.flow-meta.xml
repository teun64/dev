<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <description>Escalation flow for direct debit setup requests. When Interaction_Status__c is set to &apos;Mail Sent&apos;, sends reminder emails at D+2 and D+4, then creates an escalation case at D+6 if the customer has not yet completed the authorisation.</description>
    <environments>Default</environments>
    <interviewLabel>rab - Payment - Direct Debit Escalation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>rab - Payment - Direct Debit Escalation</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>

    <!-- ═══════════════════════════════════════════════════════════════════════
