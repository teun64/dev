    <decisions>
        <description>Done to see if case should be assigned to general Voicemail queue or to miFleet Support</description>
        <name>Account_and_Skill_Assignment_Check</name>
        <label>Account and Skill Assignment Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Assign_Queue_Dev_Name_Voicemail</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Contact Found and No Fleet Skill</defaultConnectorLabel>
        <rules>
            <name>Skill_Assignment_Filled_for_Fleet</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rCase.Last_Queue__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>gqSupportFleet1</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Assign_Queue_Dev_Name_miFleetSupport</targetReference>
            </connector>
            <label>Skill Assignment Filled for Fleet</label>
        </rules>
        <rules>
            <name>Contact_Found_Account_to_be_Checked</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>vHasContact</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Account_Fleet</targetReference>
            </connector>
            <label>Contact Found, Account to be Checked</label>
        </rules>
    </decisions>
