            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>dgr_01_Contact</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ass_01_Contact</targetReference>
            </connector>
            <label>Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Account_Fleet</name>
        <label>Is Account Fleet?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Queue_Dev_Name_Voicemail</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Account is Security</defaultConnectorLabel>
        <rules>
            <name>Yes_Account_is_Fleet</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>rContact.Account.Market__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Fleet</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Queue_Dev_Name_miFleetSupport</targetReference>
            </connector>
            <label>Yes Account is Fleet</label>
        </rules>
    </decisions>
