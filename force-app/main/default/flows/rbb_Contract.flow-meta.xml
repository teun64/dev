    <description>Generic flow on contract on create and update before save</description>
    <environments>Default</environments>
    <formulas>
        <name>fAsset</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!$Record.Entity__c},{!$Record.Hardware__c})</expression>
    </formulas>
    <formulas>
        <name>fMonthsInAdvanceActivated</name>
        <dataType>Number</dataType>
        <expression>BLANKVALUE({!$Record.Account.OrderOffsetTerm__c},0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>fMonthsInAdvanceReady</name>
        <dataType>Number</dataType>
        <expression>((YEAR({!$Record.StartDate}) - YEAR(TODAY())) * 12 ) + (MONTH({!$Record.StartDate})- MONTH(TODAY())) + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Contract Name</description>
        <name>fName</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!$Record.Base_Product__r.Article_Number_Exact__c},BLANKVALUE(TEXT({!$Record.Base_Product__r.Family}),&apos;?&apos;))</expression>
    </formulas>
    <formulas>
        <name>fPaymentType</name>
        <dataType>String</dataType>
        <expression>LOWER(LEFT(BLANKVALUE(TEXT({!$Record.Payment_Method__c}),BLANKVALUE(TEXT({!$Record.Account.Payment_Method_Contracts__c}),&apos;I8&apos;)),1))</expression>
    </formulas>
