ISNUMBER(TEXT({!$Record.Payment_Method__c}))
,
VALUE(TEXT({!$Record.Payment_Method__c}))
,
IF(
ISNUMBER(RIGHT(TEXT({!$Record.Payment_Method__c}),1))
,
CASE(RIGHT(TEXT({!$Record.Payment_Method__c}),1),&apos;3&apos;,30,&apos;4&apos;,14,&apos;6&apos;,60,&apos;8&apos;,8,0)
,
