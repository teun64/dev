        <expression>{!$Record.Subscription25__Due_Date__c}
+
IF((UPPER(LEFT(TEXT({!$Record.Payment_Method__c}),1)) = &apos;I&apos;)
,
CASE(WEEKDAY({!$Record.Subscription25__Due_Date__c}),1,1,7,2,0)
,
0
)</expression>
