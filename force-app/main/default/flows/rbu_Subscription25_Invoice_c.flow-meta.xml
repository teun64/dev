+ IF(OR(ISPICKVAL({!$Record.Subscription25__Account__r.Invoice_Frequency__c},&apos;Weekly&apos;),ISPICKVAL({!$Record.Subscription25__Account__r.Invoice_Frequency__c},&apos;Daily&apos;)),&apos; - &apos; + RIGHT(&apos;00&apos; + TEXT(DAY({!fInvoiceDescriptionDate})),2),&apos;&apos;)
