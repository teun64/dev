    <formulas>
        <name>fDueDate</name>
        <dataType>Date</dataType>
        <expression>IF(ISPICKVAL({!$Record.Payment_Method__c},&apos;I0&apos;)
,
IF(
(DAY({!$Record.Due_Date_Base__c})&gt;9)
,
DATE(YEAR(ADDMONTHS({!$Record.Due_Date_Base__c},1)),MONTH(ADDMONTHS({!$Record.Due_Date_Base__c},1)),20)
,
DATE(YEAR({!$Record.Due_Date_Base__c}),MONTH({!$Record.Due_Date_Base__c}),20)
)
,
({!$Record.Due_Date_Base__c} + {!vDuePeriod})
)</expression>
    </formulas>
    <formulas>
        <name>fDueDateBase</name>
        <dataType>Date</dataType>
