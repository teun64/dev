        <defaultConnectorLabel>Do Not Route Case</defaultConnectorLabel>
        <rules>
            <name>Do_Route_Case</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>input_record.Status</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Waiting for Customer</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>input_record.IsClosed</leftValueReference>
                <operator>EqualTo</operator>
