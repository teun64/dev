                    <stringValue>Urgent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Pending_Service_Routing.IsInterruptible</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Route_Case</targetReference>
            </connector>
            <label>Re-route case</label>
        </rules>
    </decisions>
