<apex:page standardController="OAuth_Token__c" extensions="Ctrl_OAuth" showHeader="true" sidebar="true" lightningStylesheets="true">
	<apex:slds />
	<apex:pageMessages id="messages" />
	<apex:outputPanel rendered="{!action == 'authorize'}">
		Click the button below to be redirected to Exact to authorize Salesforce to have access.
		<form method="GET" action="{!OAuth_Token__c.Endpoint__c}/api/oauth2/auth" target="_parent">
			<input type="hidden" name="client_id" value="{!OAuth_Token__c.Client_Id__c}" />
			<input type="hidden" name="redirect_uri" value="{!currentUrl}?Id={!OAuth_Token__c.Id}" />
			<input type="hidden" name="response_type" value="code" />
			<input type="hidden" name="force_login" value="0" />
			<input type="submit" value="Authorize" />
		</form>
	</apex:outputPanel>
	<apex:form >
		<apex:outputPanel rendered="{!action == 'getRefreshToken'}">
			Authorization was successful, click the button below to complete the process.
			<apex:commandButton action="{!getRefreshToken}" value="Get Refresh Token" rerender="messages" />
		</apex:outputPanel>
	</apex:form>

	<apex:outputText value="{!OAuth_Token__c.Client_Secret__c}" rendered="false" />
</apex:page>