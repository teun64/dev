                      description="Relative path to the privacy policy page within this site." />
            <property name="termsPath"
                      type="String"
                      label="Terms page path"
                      default="/terms"
                      description="Relative path to the terms and conditions page within this site." />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
