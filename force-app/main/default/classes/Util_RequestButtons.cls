global with sharing class Util_RequestButtons {
    private static Map<String, String> miSyncSettings;

	public static String getMiHttpResponse(String endpoint, String objectExtId){
		return Util_RequestButtons.getMiHttpResponse(endpoint, objectExtId, 'GET', null);
	}

    public static String getMiHttpResponse(String endpoint, String objectExtId, String method, String body){
        Util_RequestButtons.setMiSyncSettings();
		Long currentTime = (DateTime.now().getTime())/1000; //divide by 1000; the epoch generated by SF is in milliseconds, Mi not
		String apikey = Util_RequestButtons.miSyncSettings.get('Mi_API_Secret');
		String randomstring = Util_System.generateRandomString(10);

		HttpRequest req = new HttpRequest();
		req.setMethod(method);
		req.setTimeout(120000);
		req.setEndpoint(endpoint + (!String.isBlank(objectExtId) ? objectExtId : ''));
		req.setHeader('X-Mi-User', Util_RequestButtons.miSyncSettings.get('Mi_API_Username'));
		req.setHeader('X-Mi-Nonce', randomstring);
		req.setHeader('X-Mi-Timestamp', String.valueOf(currentTime));

		//header values need to be concatenated and hashed and hexed in the last header.
		String concatHeaders = req.getEndpoint().substringAfter('.com') + Util_RequestButtons.miSyncSettings.get('Mi_API_Username') + randomstring + String.valueOf(currentTime) + apikey;
		String hashedHeaders = EncodingUtil.convertToHex(Crypto.generateDigest('SHA512', Blob.valueOf(concatHeaders)));
		req.setHeader('X-Signature', 'sha512 ' + hashedHeaders);

		//add the body
		if(!String.isBlank(body)){
			req.setBody(body);
			req.setHeader('Content-Type', 'application/json');
		}

		Http http = new Http();
		HTTPResponse res = http.send(req);

		if(res.getStatusCode() != 200){
			throw new Util_Rest.UpsertException('Error: ' + res.getBody());
		} else if(String.isBlank(res.getBody().replace('[]',''))){
			throw new Util_Rest.UpsertException('Error: ' + 'Received an empty response from MI. No data available.');
		}

		return res.getBody();
	}

    private static void setMiSyncSettings(){
        List<Mi_Sync_Setting__mdt> syncSettings = [SELECT MasterLabel, DeveloperName, Value__c FROM Mi_Sync_Setting__mdt];
        if(syncSettings == null){
            throw new Util_RequestButtons.OnDemandException('Error: No Mi Settings found. Make sure Mi settings exists as custom metadata.');
        }
        Util_RequestButtons.miSyncSettings = new Map<String, String>();
        for(Mi_Sync_Setting__mdt syncSetting :syncSettings){
            miSyncSettings.put(syncSetting.DeveloperName, syncSetting.Value__c);
        }
    }

	public class OnDemandException extends Exception {}
}