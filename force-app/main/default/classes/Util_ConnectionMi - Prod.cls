public with sharing class Util_ConnectionMi {
	//simpleton stuff
	private static Map<String, Util_ConnectionMi> instances = new Map<String, Util_ConnectionMi>();
	public static Util_ConnectionMi getInstance(String namedCredential, String eventLogId){
		if(!Util_ConnectionMi.instances.containsKey(namedCredential)){
			Util_ConnectionMi inst = new Util_ConnectionMi(namedCredential);
			Util_ConnectionMi.instances.put(namedCredential, inst);
		}
		Util_ConnectionMi instance = Util_ConnectionMi.instances.get(namedCredential);
		instance.eventLogId = eventLogId; //this will mean that all logs from this call will use the given event log
		return instance;
	}

	private final String executionId;
	private String eventLogId;
	private String namedCredentialName;
	private String baseURL;
	private String userName;
	private String clientSecret;
	private String environment;

	//logging stuff
	private List<Util_ConnectionMi.LogWrapper> logs = new List<Util_ConnectionMi.LogWrapper>();

	//private constructor, because getInstance should be used
	private Util_ConnectionMi(String namedCredential){
		this.executionId = Util_System.generateGUID();
		this.namedCredentialName = namedCredential;
		String environmentName = DomainParser.parse(DomainCreator.getOrgMyDomainHostname()).getSandboxName();
		if(String.isBlank(environmentName)){
			environmentName = 'Prod';
		}

		this.environment = environmentName.toLowerCase();

		String devName = this.environment + '_' + namedCredential.toLowerCase();

        Platform_Connection_Setting__mdt platformSettings = [SELECT DeveloperName, Environment__c, NamedCredential__c, Secret__c, Username__c, baseURL__c  
														FROM Platform_Connection_Setting__mdt
														WHERE DeveloperName = :devName
														LIMIT 1];
        if(platformSettings == null){
            throw new Util_System.CustomException('Error: No Mi Settings found. Make sure Mi settings exists as custom metadata.');
        }

		this.baseURL = platformSettings.baseURL__c;
		this.userName = platformSettings.Username__c;
		this.clientSecret = platformSettings.Secret__c;
	}

	public void saveToken(){
		//actually only storing logs at this point...
		Map<String, OAuth_Log__c> logsToInsert = new Map<String, OAuth_Log__c>();
		Map<String, List<ContentVersion>> versionsPerLog = new Map<String, List<ContentVersion>>();
		List<ContentVersion> allVersions = new List<ContentVersion>();

		for(Util_ConnectionMi.LogWrapper logWrap : this.logs){
			logsToInsert.put(logWrap.log.GUID__c, logWrap.log);

			List<ContentVersion> versions = logWrap.getContentVersions();
			versionsPerLog.put(logWrap.log.GUID__c, versions);
			allVersions.addAll(versions);
		}

		Database.insert(logsToInsert.values());
		Database.insert(allVersions);

		//we have to requery the versions to get the contentdocumentids so we can save the contentdocumentlinks
		Map<Id, ContentVersion> versions = new Map<Id, ContentVersion>([SELECT Id, ContentDocumentId FROM ContentVersion WHERE Id IN :allVersions]);
		List<ContentDocumentLink> linksToCreate = new List<ContentDocumentLink>();
		for(String logGuid : versionsPerLog.keySet()){
			for(ContentVersion file : versionsPerLog.get(logGuid)){
				ContentDocumentLink link = new ContentDocumentLink();
				link.LinkedEntityId = logsToInsert.get(logGuid).Id;
				link.ContentDocumentId = versions.get(file.Id).ContentDocumentId;
				link.ShareType = 'I'; //inherit sharing from the linked object
				linksToCreate.add(link);
			}
		}
		Database.insert(linksToCreate);
	}

	//some optional parameters here; addAuth and content, default values are true and null
	public HttpResponse doRequest(String endpoint, Map<String, String> params){
		return this.doRequest(endpoint, params, 'GET', null);
	}

	public HttpResponse doRequest(String endpoint, Map<String, String> params, String method) {
		return this.doRequest(endpoint, params, method, null);
	}

	//private HttpResponse doRequest(String endpoint, Map<String, String> params, String method, Boolean addAuth, String content) {
    public HttpResponse doRequest(String endpoint, Map<String, String> params, String method, String content) {
		//create the param string, and based on the method append it to the endpoint (GET) or
		//set the param string as the content (POST)
	    Long currentTime = (DateTime.now().getTime())/1000; //divide by 1000; the epoch generated by SF is in milliseconds, Mi not
		String randomstring = Util_System.generateRandomString(10);
        String objectId = '';

        if ((params != null) && (params.size() >= 1) && (params.containsKey('objectId'))) {
            objectId = params.get('objectId');
        }

		String reqEndpoint = this.baseURL + endpoint;

		if (String.isNotBlank(objectId)) {
			reqEndpoint += '/' + objectId;
		}       
		reqEndpoint = reqEndpoint.replace(' ', '+');
		//System.debug('Util_ConnectionMi -> endpoint : ' + reqEndpoint);

	    //create the request with the appropriate headers, content and endpoint
        HttpRequest request = new HttpRequest();
		request.setMethod(method);
		request.setTimeout(120000);
		request.setEndpoint(reqEndpoint);
        request.setHeader('X-Mi-User', this.userName);
		request.setHeader('X-Mi-Nonce', randomstring);
		request.setHeader('X-Mi-Timestamp', String.valueOf(currentTime));

		//header values need to be concatenated and hashed and hexed in the last header.
		String concatHeaders = request.getEndpoint().substringAfter('.com') + this.userName + randomstring + String.valueOf(currentTime) + this.clientSecret;
		String hashedHeaders = EncodingUtil.convertToHex(Crypto.generateDigest('SHA512', Blob.valueOf(concatHeaders)));
		request.setHeader('X-Signature', 'sha512 ' + hashedHeaders);

		//if we're sending a payload, set the content length and the request body
		if(!String.isBlank(content)){
			//request.setHeader('Content-Type', 'application/json');
			request.setHeader('Content-Length', String.valueOf(content.length()));
			request.setBody(content);
		}

		//set the Accept header and for non-GET requests, also set the content type to JSON.
		if(method != 'GET') {
			request.setHeader('Content-Type', 'application/json');
			request.setHeader('Prefer', 'return=representation');
		}

		Util_ConnectionMi.LogWrapper log = new Util_ConnectionMi.LogWrapper(this.executionId, this.eventLogId, request);
         
		// get a response
		HTTP http = new HTTP();
		HTTPResponse response;
		Boolean isException = false;
		
		try {
			response = http.send(request);

			if(response.getStatusCode() != 200){
				throw new Util_System.ConnectionException('Error: ' + response.getBody());
			} else if(String.isBlank(response.getBody().replace('[]',''))){
				throw new Util_System.ConnectionException('Error: ' + 'Received an empty response from MI. No data available.');
			}
		} catch (exception conEx) {
			isException = true;
			//throw connectionEx;
			throw conEx;
		} finally {
			log.logResponse(response);
			this.logs.add(log);
		}

		return response;
	}

	// TODO move to Util_OAuth
	private class LogWrapper {
		private OAuth_Log__c log;
		private HttpRequest request;
		private HttpResponse response;
		private String requestBody;
		private String responseBody;

		private LogWrapper(String execId, String eventLogId, HttpRequest req){
			this.log = new OAuth_Log__c(GUID__c = Util_System.generateGUID());
			if(!String.isBlank(eventLogId)){
				this.log.Event_Log__r = new Event_Log__c(GUID__c = eventLogId);
			}
			this.log.Execution_Id__c = execId;
			this.log.Endpoint__c = req.getEndpoint();
			this.log.Method__c = req.getMethod();
			this.request = req;
		}

		private void logResponse(HttpResponse res){
			this.response = res;
			this.log.Status_Code__c = res.getStatusCode();
		}

		private List<ContentVersion> getContentVersions(){
			List<ContentVersion> versions = new List<ContentVersion>();
			if(!String.isBlank(this.request.getBody())){
				ContentVersion requestFile = new ContentVersion();
				requestFile.VersionData = Blob.valueOf(this.request.getBody());
				requestFile.PathOnClient = 'request-txt';
				requestFile.Title = 'request.txt';
				versions.add(requestFile);
			}
			if(!String.isBlank(this.response.getBody())){
				ContentVersion responseFile = new ContentVersion();
				responseFile.VersionData = Blob.valueOf(this.response.getBody());
				responseFile.PathOnClient = 'response-txt';
				responseFile.Title = 'response.txt';
				versions.add(responseFile);
			}
			return versions;
		}
	}
}
