                  "type" : "block",
                  "children" : [ {
                    "attributes" : {
                      "align" : "left",
                      "text" : "Download de MiApp op uw smartphone. Daarmee kunt u op afstand een eventuele blokkade opheffen. Log alvast een keer in, zodat u zeker weet dat alles werkt."
                    },
                    "definition" : "lightning/paragraph",
                    "id" : "538d527d-277e-4a1c-8f89-d3893a806214",
